<?xml version="1.0" encoding="utf-8"?>
<!--
  CR20 Robot - URDF para NVIDIA Isaac Sim
  - SIN world link
  - SIN dummy_link
  - Damping reducido
  - base_link es el ROOT
-->
<robot name="cr20_robot">

  <!-- ========== BASE LINK (ROOT) ========== -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.0523349568972135 0.0899270486094572 -0.00279275668479641" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                          iyy="0.01" iyz="0.0"
                                     izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/iudc/dobot_ws/src/DOBOT_6Axis_ROS2_V4/cra_description/meshes/cr20/base_link.STL"/>
      </geometry>
      <material name="robot_blue">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/iudc/dobot_ws/src/DOBOT_6Axis_ROS2_V4/cra_description/meshes/cr20/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ========== LINK 1 ========== -->
  <link name="Link1">
    <inertial>
      <origin xyz="-0.0154576425326206 -0.0986375365415087 1.04119647925812" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0"
                          iyy="0.05" iyz="0.0"
                                     izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/iudc/dobot_ws/src/DOBOT_6Axis_ROS2_V4/cra_description/meshes/cr20/Link1.STL"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/iudc/dobot_ws/src/DOBOT_6Axis_ROS2_V4/cra_description/meshes/cr20/Link1.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0 0 0.23" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child  link="Link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="150" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ========== LINK 2 ========== -->
  <link name="Link2">
    <inertial>
      <origin xyz="-0.828898669983325 -3.97165169431493E-07 0.115283168336158" rpy="0 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.1"  ixy="0.0" ixz="0.0"
                          iyy="0.1"  iyz="0.0"
                                     izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="/home/iudc/dobot_ws/src/DOBOT_6Axis_ROS2_V4/cra_description/meshes/cr20/Link2.STL"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
