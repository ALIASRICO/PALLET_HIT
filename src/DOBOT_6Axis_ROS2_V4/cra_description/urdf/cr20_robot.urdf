    <child  link="Link3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9" upper="2.9" effort="150" velocity="3.14"/>
    <dynamics damping="0.3" friction="0.1"/>
  </joint>

  <!-- ========== LINK 4 ========== -->
  <link name="Link4">
    <inertial>
      <origin xyz="1.09076486456641E-07 -0.0757301256894509 1.20551504334543E-08" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.01"  ixy="0.0" ixz="0.0"
