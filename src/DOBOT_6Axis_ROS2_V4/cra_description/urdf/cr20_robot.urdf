    <!-- FIXED = pegado a Link6, no se mueve solo -->
    <joint name="gripper_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="Link6"/>
      <child link="gripper_link"/>
    </joint>

</robot>