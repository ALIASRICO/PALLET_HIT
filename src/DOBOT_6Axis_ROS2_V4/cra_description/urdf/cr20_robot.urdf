      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="/home/iudc/dobot_ws/src/DOBOT_6Axis_ROS2_V4/cra_description/meshes/cr20/gripper_link.stl"/>
        </geometry>
