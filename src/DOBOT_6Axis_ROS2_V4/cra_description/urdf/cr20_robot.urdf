  <!-- ========== LINK 6 ========== -->
  <link name="Link6">
    <inertial>
      <origin xyz="0.0154576401891996 0.658802608062882 -0.213462466800391" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0"
                           iyy="0.002" iyz="0.0"
