  <joint name="joint2" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 1.5708 0"/>
    <parent link="Link1"/>
    <child  link="Link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28" upper="6.28" effort="150" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ========== LINK 3 ========== -->
  <link name="Link3">
    <inertial>
      <origin xyz="-0.746000007821945 1.07337005127015E-07 0.0757301295800403" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0"
                          iyy="0.05" iyz="0.0"
                                     izz="0.01"/>
